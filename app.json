{
  "expo": {
    "name": "odia-agent",
    "slug": "odia-agent",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#E65100"
    },
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.odiaenglish",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "This app requires microphone access to record Odia phrases for speech translation features."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E65100",
        "foregroundImage": "./assets/icon.png"
      },
      "package": "com.yourname.odiaenglish",
      "versionCode": 1,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-splash-screen",
      "expo-dev-client",
      "expo-sqlite"
    ],
    "extra": {
      "eas": {
        "projectId": "c59d6386-7f59-4f65-b40c-d131f172f87c"
      }
    }
  }
}
